rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Fields: name (string), category (string), price (number), stock (number), unit (string), description (string)
    //
    // Collection: procurements
    // Fields: productId (string), productName (string), category (string), quantity (number), buyPrice (number), supplier (string), date (timestamp)
    //
    // Collection: sales
    // Fields: items (array), totalAmount (number), date (timestamp), customer (string)
    //
    // Collection: users
    // Fields: displayName (string), email (string), role (string)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         (request.auth.token.email == "diyaznajib.93@gmail.com" && request.auth.token.email_verified == true));
    }

    function isStaff() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'staff', 'viewer']) ||
         (request.auth.token.email == "diyaznajib.93@gmail.com" && request.auth.token.email_verified == true));
    }

    // Validation Functions
    function isValidProduct(data) {
      return data.keys().hasAll(['sku', 'name', 'category', 'price', 'stock', 'unit']) &&
             data.sku is string && data.sku.size() > 0 && data.sku.size() < 50 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.category in ['Barang', 'Pangan'] &&
             data.price is number && data.price >= 0 &&
             data.stock is number &&
             data.unit is string && data.unit.size() > 0 && data.unit.size() < 20;
    }

    function isValidProcurement(data) {
      return data.keys().hasAll(['productId', 'sku', 'productName', 'category', 'quantity', 'buyPrice', 'supplier', 'date']) &&
             data.productId is string &&
             data.sku is string &&
             data.productName is string &&
             data.category in ['Barang', 'Pangan'] &&
             data.quantity is number && data.quantity > 0 &&
             data.buyPrice is number && data.buyPrice >= 0 &&
             data.supplier is string && data.supplier.size() > 0 &&
             data.date is timestamp;
    }

    function isValidSale(data) {
      return data.keys().hasAll(['items', 'totalAmount', 'date']) &&
             data.items is list && data.items.size() > 0 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.date is timestamp;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'email', 'role']) &&
             data.displayName is string && data.displayName.size() > 0 &&
             data.email is string &&
             data.role in ['admin', 'staff', 'viewer'] &&
             (!('isPendingAdmin' in data) || data.isPendingAdmin is bool) &&
             (!('isMainAdmin' in data) || data.isMainAdmin is bool);
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && (request.auth.uid == userId || isAdmin()) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create, update: if isStaff() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /procurements/{procurementId} {
      allow read: if isAuthenticated();
      allow create: if isStaff() && isValidProcurement(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /sales/{saleId} {
      allow read: if isAuthenticated();
      allow create: if isStaff() && isValidSale(request.resource.data);
      allow update, delete: if isAdmin();
    }
  }
}
