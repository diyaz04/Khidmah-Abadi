rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Fields: sku (string), name (string), category (string), price (number), stock (number), unit (string), description (string), imageUrl (string)
    //
    // Collection: procurements
    // Fields: productId (string), sku (string), productName (string), category (string), quantity (number), buyPrice (number), supplier (string), date (timestamp)
    //
    // Collection: sales
    // Fields: items (array), totalAmount (number), date (timestamp), customer (string), address (string), dueDate (string)
    //
    // Collection: users
    // Fields: displayName (string), email (string), role (string), isPendingAdmin (bool), isMainAdmin (bool), isApprovedViewer (bool)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "diyaznajib.93@gmail.com" ||
         request.auth.token.email == "admin@khidmah.com" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          (getUserData().role == 'admin' || getUserData().get('isMainAdmin', false) == true) &&
          getUserData().get('isPendingAdmin', false) == false));
    }

    function isMainAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "diyaznajib.93@gmail.com" ||
         request.auth.token.email == "admin@khidmah.com" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          getUserData().get('isMainAdmin', false) == true));
    }

    function isStaff() {
      return isAuthenticated() && 
        (request.auth.token.email == "diyaznajib.93@gmail.com" ||
         request.auth.token.email == "admin@khidmah.com" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          (getUserData().role in ['admin', 'staff'] || getUserData().get('isMainAdmin', false) == true) &&
          getUserData().get('isPendingAdmin', false) == false));
    }

    function isApprovedViewer() {
      return isAuthenticated() && 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData().role == 'viewer' && 
         getUserData().get('isApprovedViewer', false) == true);
    }

    function canReadData() {
      return isAdmin() || isStaff() || isApprovedViewer();
    }

    // Validation Functions
    function isValidProduct(data) {
      let categories = ['Barang', 'Pangan', 'Jasa', 'Buah-buahan', 'Susu', 'Roti', 'Keringan', 'Sayuran', 'Bumbu Pelengkap masak'];
      return data.keys().hasAll(['sku', 'name', 'category', 'price', 'stock', 'unit']) &&
             data.sku is string && data.sku.size() > 0 && data.sku.size() < 50 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.category in categories &&
             data.price is number && data.price >= 0 &&
             data.stock is number &&
             data.unit is string && data.unit.size() > 0 && data.unit.size() < 20 &&
             (!('description' in data) || data.description is string) &&
             (!('imageUrl' in data) || data.imageUrl is string);
    }

    function isValidProcurement(data) {
      let categories = ['Barang', 'Pangan', 'Jasa', 'Buah-buahan', 'Susu', 'Roti', 'Keringan', 'Sayuran', 'Bumbu Pelengkap masak'];
      return data.keys().hasAll(['productId', 'sku', 'productName', 'category', 'quantity', 'buyPrice', 'supplier', 'date']) &&
             data.productId is string &&
             data.sku is string &&
             data.productName is string &&
             data.category in categories &&
             data.quantity is number && data.quantity > 0 &&
             data.buyPrice is number && data.buyPrice >= 0 &&
             data.supplier is string && data.supplier.size() > 0 &&
             data.date is timestamp;
    }

    function isValidSale(data) {
      return data.keys().hasAll(['items', 'totalAmount', 'date']) &&
             data.items is list && data.items.size() > 0 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.date is timestamp &&
             (!('customer' in data) || data.customer is string) &&
             (!('address' in data) || data.address is string) &&
             (!('dueDate' in data) || data.dueDate is string);
    }

    function isValidUser(data) {
      return isAdmin() || (
        data.keys().hasAll(['displayName', 'email', 'role']) &&
        data.keys().hasOnly(['uid', 'displayName', 'email', 'role', 'isPendingAdmin', 'isMainAdmin', 'isApprovedViewer', 'createdAt', 'isPreRegistered', 'lastLogin', 'password']) &&
        data.displayName is string && data.displayName.size() > 0 &&
        data.email is string &&
        data.role in ['admin', 'staff', 'viewer'] &&
        (!('uid' in data) || data.uid is string) &&
        (!('createdAt' in data) || data.createdAt is timestamp) &&
        (!('lastLogin' in data) || data.lastLogin is timestamp) &&
        (!('isPendingAdmin' in data) || data.isPendingAdmin is bool) &&
        (!('isMainAdmin' in data) || data.isMainAdmin is bool) &&
        (!('isPreRegistered' in data) || data.isPreRegistered is bool) &&
        (!('isApprovedViewer' in data) || data.isApprovedViewer is bool) &&
        (!('password' in data) || (data.password is string && data.password.size() >= 6 && data.password.size() < 100))
      );
    }

    // Rules
    match /test/connection {
      allow read: if true;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if (isOwner(userId) || isAdmin()) && 
                      isValidUser(request.resource.data) &&
                      (isAdmin() || (
                        request.resource.data.role != 'admin' &&
                        request.resource.data.get('isPendingAdmin', true) == true
                      ));
      allow update: if (isOwner(userId) || isAdmin()) && 
                      isValidUser(request.resource.data) &&
                      (isAdmin() || (
                        request.resource.data.role == resource.data.role &&
                        request.resource.data.get('isPendingAdmin', false) == resource.data.get('isPendingAdmin', false) &&
                        request.resource.data.get('isMainAdmin', false) == resource.data.get('isMainAdmin', false) &&
                        request.resource.data.get('isApprovedViewer', false) == resource.data.get('isApprovedViewer', false)
                      ));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.get('isPreRegistered', false) == true && resource.data.email == request.auth.token.email);
    }

    match /products/{productId} {
      allow read: if canReadData();
      allow create: if isStaff() && isValidProduct(request.resource.data);
      allow update: if (isStaff() && isValidProduct(request.resource.data)) || 
                      (isMainAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['description']));
      allow delete: if isAdmin();
    }

    match /procurements/{procurementId} {
      allow read: if isAdmin() || isStaff();
      allow create: if isStaff() && isValidProcurement(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /sales/{saleId} {
      allow read: if isAdmin() || isStaff();
      allow create: if isStaff() && isValidSale(request.resource.data);
      allow update, delete: if isAdmin();
    }
  }
}
