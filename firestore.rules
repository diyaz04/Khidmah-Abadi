rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default: Deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth Helper
    function isSignedIn() {
      return request.auth != null;
    }

    // Get User Data
    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : {};
    }

    // ROLE HELPERS
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "diyaznajib.93@gmail.com" || 
        request.auth.token.email == "admin@khidmah.com" ||
        getUserData().get('isMainAdmin', false) == true ||
        (getUserData().get('role', '') == 'admin' && getUserData().get('isPendingAdmin', true) == false)
      );
    }

    function isStaff() {
      return isAdmin() || (
        isSignedIn() && 
        getUserData().get('role', '') == 'staff' && 
        getUserData().get('isPendingAdmin', true) == false
      );
    }

    function isViewer() {
      return isStaff() || (
        isSignedIn() && 
        getUserData().get('role', '') == 'viewer' && 
        getUserData().get('isApprovedViewer', false) == true
      );
    }

    // USER RULES
    match /users/{userId} {
      // Perkara permission dipermudah agar tidak ada hambatan akses profil sama sekali
      // Sengaja dibuka full untuk mengatasi error 'Missing or insufficient permissions' saat registrasi/claim
      allow read, write: if true;
    }

    // INVENTORY RULES
    match /products/{productId} {
      // Any verified user (no matter the role) can see products if they are logged in
      allow read: if isSignedIn();
      // Admin and Staff can manage products
      allow write: if isStaff();
    }

    // PROCUREMENT RULES
    match /procurements/{procurementId} {
      allow read, write: if isStaff();
    }

    // SALES RULES
    match /sales/{saleId} {
      allow read, write: if isStaff();
    }
    
    // Connection test
    match /test/connection {
      allow read: if true;
    }
  }
}
