{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product available for sale or procurement.",
      "type": "object",
      "properties": {
        "sku": { "type": "string", "description": "Product SKU/ID" },
        "name": { "type": "string", "description": "Product name" },
        "category": { "type": "string", "enum": ["Barang", "Pangan", "Jasa", "Buah-buahan", "Susu", "Roti", "Keringan", "Sayuran", "Bumbu Pelengkap masak"], "description": "Product category" },
        "price": { "type": "number", "description": "Selling price" },
        "stock": { "type": "number", "description": "Current stock level" },
        "unit": { "type": "string", "description": "Unit of measurement (pcs, kg, liter, etc.)" },
        "description": { "type": "string", "description": "Optional product description" },
        "imageUrl": { "type": "string", "description": "Optional product image URL" }
      },
      "required": ["sku", "name", "category", "price", "stock", "unit"]
    },
    "Procurement": {
      "title": "Procurement",
      "description": "A record of product procurement from a supplier.",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "Reference to the product" },
        "sku": { "type": "string", "description": "Product SKU/ID" },
        "productName": { "type": "string", "description": "Name of the product at time of procurement" },
        "category": { "type": "string", "enum": ["Barang", "Pangan", "Jasa", "Buah-buahan", "Susu", "Roti", "Keringan", "Sayuran", "Bumbu Pelengkap masak"], "description": "Product category" },
        "quantity": { "type": "number", "description": "Quantity received" },
        "buyPrice": { "type": "number", "description": "Purchase price per unit" },
        "supplier": { "type": "string", "description": "Supplier name" },
        "date": { "type": "string", "format": "date-time", "description": "Date of procurement" }
      },
      "required": ["productId", "sku", "productName", "category", "quantity", "buyPrice", "supplier", "date"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A record of a sales transaction.",
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" },
              "total": { "type": "number" }
            },
            "required": ["productId", "name", "quantity", "price", "total"]
          }
        },
        "totalAmount": { "type": "number", "description": "Total transaction amount" },
        "date": { "type": "string", "format": "date-time", "description": "Date of sale" },
        "customer": { "type": "string", "description": "Optional customer name" }
      },
      "required": ["items", "totalAmount", "date"]
    },
    "User": {
      "title": "User",
      "description": "Application user profile.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff", "viewer"] },
        "isPendingAdmin": { "type": "boolean" },
        "isMainAdmin": { "type": "boolean" },
        "isApprovedViewer": { "type": "boolean" }
      },
      "required": ["displayName", "email", "role"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer information.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Customer/Agency name" },
        "address": { "type": "string", "description": "Physical address" },
        "phone": { "type": "string", "description": "Contact phone number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "address", "phone"]
    }
  },
  "firestore": {
    "/products/{productId}": { "schema": "Product", "description": "Product collection" },
    "/procurements/{procurementId}": { "schema": "Procurement", "description": "Procurement records" },
    "/sales/{saleId}": { "schema": "Sale", "description": "Sales transactions" },
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/customers/{customerId}": { "schema": "Customer", "description": "Customer records" }
  }
}
